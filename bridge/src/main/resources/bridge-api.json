{
    "title": "ES-TOK Bridge 接口",
    "summary": "bridge CLI 通过标准输入/输出暴露共享的 ES-TOK Java core，供 Python 和其他非 JVM 调用方复用同一套分析语义。",
    "transport": {
        "request": "向标准输入写入一个 JSON 对象",
        "response": "从标准输出读取一个 JSON 对象"
    },
    "request": {
        "description": "bridge 至少需要 `text` 字段；其余字段会继续传给 ES-TOK 配置加载器。嵌套配置对象保持与插件 REST 分析接口一致的命名。",
        "required": [
            "text"
        ],
        "properties": {
            "text": {
                "type": "string",
                "required": true,
                "description": "待分析文本。为空或缺失时返回错误。"
            },
            "use_vocab": {
                "type": "boolean",
                "required": false,
                "description": "是否启用词表分词。默认值为 true，与插件分析接口保持一致。"
            },
            "use_categ": {
                "type": "boolean",
                "required": false,
                "description": "是否启用分类分词。"
            },
            "use_ngram": {
                "type": "boolean",
                "required": false,
                "description": "是否启用 N-gram 生成。"
            },
            "use_rules": {
                "type": "boolean",
                "required": false,
                "description": "是否启用规则过滤。"
            },
            "extra_config": {
                "type": "object",
                "required": false,
                "description": "可选的 extra 嵌套配置，例如 ignore_case、ignore_hant、drop_duplicates、drop_categs。"
            },
            "categ_config": {
                "type": "object",
                "required": false,
                "description": "可选的 categ 嵌套配置，例如 split_word。"
            },
            "vocab_config": {
                "type": "object",
                "required": false,
                "description": "可选的 vocab 嵌套配置。当省略且 use_vocab 为 true 时，会默认补上 vocab_config.file = vocabs.txt。"
            },
            "ngram_config": {
                "type": "object",
                "required": false,
                "description": "可选的 ngram 嵌套配置，例如 use_bigram、use_vbgram、use_vcgram、drop_cogram。"
            },
            "rules_config": {
                "type": "object",
                "required": false,
                "description": "可选的 rules 嵌套配置或规则文件引用。"
            }
        }
    },
    "response": {
        "properties": {
            "tokens": {
                "type": "array",
                "required": true,
                "description": "共享 Java core 输出的有序 token 列表。",
                "items": {
                    "type": "object",
                    "properties": {
                        "token": {
                            "type": "string",
                            "required": true,
                            "description": "归一化后的 token 文本。"
                        },
                        "start_offset": {
                            "type": "integer",
                            "required": true,
                            "description": "在分析文本中的起始偏移，包含起点。"
                        },
                        "end_offset": {
                            "type": "integer",
                            "required": true,
                            "description": "在分析文本中的结束偏移，不包含终点。"
                        },
                        "type": {
                            "type": "string",
                            "required": true,
                            "description": "Lucene token 类型，例如 cjk、vocab、bigram。"
                        },
                        "group": {
                            "type": "string",
                            "required": true,
                            "description": "ES-TOK 分组，例如 categ、vocab、ngram。"
                        },
                        "position": {
                            "type": "integer",
                            "required": true,
                            "description": "token 在最终有序输出中的位置。"
                        }
                    }
                }
            },
            "version": {
                "type": "object",
                "required": true,
                "description": "描述当前分析行为和资源快照的版本哈希。",
                "properties": {
                    "analysis_hash": {
                        "type": "string",
                        "required": true,
                        "description": "有效分析配置以及关联资源哈希组合后的指纹。"
                    },
                    "vocab_hash": {
                        "type": "string",
                        "required": true,
                        "description": "解析后词表内容的哈希；当词表关闭时返回 `disabled`。"
                    },
                    "rules_hash": {
                        "type": "string",
                        "required": true,
                        "description": "解析后规则内容的哈希；当规则关闭时返回 `disabled`。"
                    }
                }
            }
        }
    },
    "examples": [
        {
            "case": "inline_vocab",
            "title": "内联词表分词"
        },
        {
            "case": "minimal_categ",
            "title": "基础分类分词"
        },
        {
            "case": "drop_categs_preserve",
            "title": "词表、分类与 N-gram 联合输出"
        }
    ]
}